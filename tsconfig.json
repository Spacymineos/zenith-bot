{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@zenith/shared": ["./src/shared/index.ts"],
      "@zenith/shared/*": ["./src/shared/*"],
      "@zenith/config": ["./src/config.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "contracts/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
