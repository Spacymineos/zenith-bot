{
  "name": "@chainbot/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./logic": {
      "types": "./dist/logic/index.d.ts",
      "import": "./dist/logic/index.js"
    },
    "./chain": {
      "types": "./dist/chain/index.d.ts",
      "import": "./dist/chain/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "zod": "^4.3.6",
    "@chainbot/config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  }
}
